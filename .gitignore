# Ignorar arquivos de cache e estado gerados pelo Node-RED e NPM
/node-red-config/.npm/
/node-red-config/_cacache/
/node-red-config/.sessions.json
/node-red-config/package-lock.json

# Ignorar logs e arquivos temporários
*.log
*.tmp

# Ignora todos os arquivos .env em qualquer subdiretório de environments
environments/**/*.env
# Ignora pastas de dados geradas pelo Nginx Proxy Manager e Portainer
# em todos os ambientes.
environments/**/nginx/
environments/**/portainer/


# Ignora todo o conteúdo da pasta de configuração do Node-RED, 
# pois são dados de runtime. 
/node-red-config/* 
# Mas NÃO ignora o arquivo .gitkeep, para que a pasta vazia seja versionada. 
!/node-red-config/.gitkeep

nul
NUL
**/nul
**/NUL

