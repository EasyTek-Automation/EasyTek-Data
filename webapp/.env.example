# =============================================================================
# EXEMPLO DE CONFIGURAÇÃO - AMG_Data
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env (está no .gitignore)

# =============================================================================
# MONGODB
# =============================================================================
MONGO_URI=mongodb://localhost:27017
DB_NAME=Cluster-EasyTek

# =============================================================================
# FLASK / DASH
# =============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
PORT=8050

# =============================================================================
# GATEWAY (Event Publisher)
# =============================================================================
GATEWAY_URL=http://localhost:5001

# =============================================================================
# LOGGING
# =============================================================================

# Nível geral de log (DEBUG | INFO | WARNING | ERROR | CRITICAL)
# Desenvolvimento: DEBUG ou INFO
# Produção: INFO ou WARNING
LOG_LEVEL=INFO

# Mostrar logs de requisições HTTP (GET, POST) do Werkzeug
# 1 = mostra, 0 = oculta (padrão - reduz poluição)
SHOW_HTTP_LOGS=0

# =============================================================================
# DEBUG SELETIVO POR PÁGINA
# =============================================================================
# Formato: DEBUG_<PAGINA>=<TIPOS>
# Tipos disponíveis: ALL, CALLBACKS, DATABASE, CALC, UI
# Separar múltiplos tipos por vírgula (sem espaços)

# === MANUTENÇÃO - INDICADORES ===
# Liga TUDO da página (callbacks + cálculos + UI + database)
DEBUG_MAINTENANCE_INDICATORS=0

# Exemplos de uso granular (descomente para usar):
# DEBUG_MAINTENANCE_INDICATORS=ALL              # Tudo
# DEBUG_MAINTENANCE_INDICATORS=CALLBACKS        # Apenas callbacks
# DEBUG_MAINTENANCE_INDICATORS=CALLBACKS,CALC   # Callbacks + cálculos
# DEBUG_MAINTENANCE_INDICATORS=CALC             # Apenas cálculos KPI

# === ENERGIA - OVERVIEW ===
DEBUG_ENERGY_OVERVIEW=0
# DEBUG_ENERGY_OVERVIEW=CALLBACKS               # Apenas callbacks
# DEBUG_ENERGY_OVERVIEW=CALLBACKS,DATABASE      # Callbacks + queries DB

# === Outras páginas (adicionar conforme necessário) ===
# DEBUG_PRODUCTION_STATES=0
# DEBUG_ALARMS=0

# =============================================================================
# FORMATO ANTIGO (ainda suportado para compatibilidade)
# =============================================================================
# DEBUG_MAINTENANCE=0      # Equivale a DEBUG_MAINTENANCE_INDICATORS=ALL
# DEBUG_KPI_CALC=0         # Equivale a DEBUG_MAINTENANCE_INDICATORS=CALC

# =============================================================================
# DOCUMENTAÇÃO (Procedures)
# =============================================================================
# DOCS_PROCEDURES_PATH=/caminho/para/volume/externo/procedures
