    {
        "id": "2b5766b293201a72",
        "type": "function",
        "z": "2b17cc635e977db5",
        "name": "function 86",
        "func": "let dadosOEE = flow.get('dadosOEE') || [];\nlet dadosDisp = flow.get('dadosDisp') || [];\nlet dadosDesemp = flow.get('dadosDesemp') || [];\nlet dadosQuali = flow.get('dadosQuali') || [];\n\nfunction media(arr) {\n    if(arr.length === 0) return null;\n    return arr.reduce((a, b) => a + b, 0) / arr.length;\n}\n\nfunction desvioPadrao(arr) {\n    if (arr.length === 0) return null;\n    let m = media(arr);\n    let variancia = arr.reduce((acum, val) => acum + Math.pow(val - m, 2), 0) / arr.length;\n    return Math.sqrt(variancia);\n}\n\nlet agora = new Date();\n\nmsg.payload = {\n    DateTime: agora,\n    IDMaq: \"Decapado Mecânico\",\n    OEE: media(dadosOEE),\n    Disp: media(dadosDisp),\n    Desemp: media(dadosDesemp),\n    Quali: media(dadosQuali)\n};\n\n// Campos SÓ para debug/monitoramento\nmsg.OEEcount = dadosOEE.length;\nmsg.Dispcount = dadosDisp.length;\nmsg.Desempcount = dadosDesemp.length;\nmsg.Qualicount = dadosQuali.length;\n\nmsg.OEEDesvio = desvioPadrao(dadosOEE);\nmsg.DispDesvio = desvioPadrao(dadosDisp);\nmsg.DesempDesvio = desvioPadrao(dadosDesemp);\nmsg.QualiDesvio = desvioPadrao(dadosQuali);\n\n// Limpa arrays\nflow.set('dadosOEE', []);\nflow.set('dadosDisp', []);\nflow.set('dadosDesemp', []);\nflow.set('dadosQuali', []);\n\nmsg.operation = \"insertOne\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 300,
        "wires": [
            [
                "46b894bb01a591ef"
            ]
        ]
    },
