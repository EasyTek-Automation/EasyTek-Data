    {
        "id": "0e87cebff72453ed",
        "type": "function",
        "z": "2b17cc635e977db5",
        "name": "function 121",
        "func": "let CorrenteR = flow.get('CorrenteR') || [];\nlet CorrenteS = flow.get('CorrenteS') || [];\nlet CorrenteT = flow.get('CorrenteT') || [];\nlet ConsumoKW = flow.get('ConsumoKW') || [];\n\nfunction media(arr) {\n    if(arr.length === 0) return null;\n    return arr.reduce((a, b) => a + b, 0) / arr.length;\n}\n\nfunction desvioPadrao(arr) {\n    if (arr.length === 0) return null;\n    let m = media(arr);\n    let variancia = arr.reduce((acum, val) => acum + Math.pow(val - m, 2), 0) / arr.length;\n    return Math.sqrt(variancia);\n}\n\nlet agora = new Date();\n\nmsg.payload = {\n    DateTime: agora,\n    IDMaq: \"Decapado Mecânico\",\n    CorrenteR: media(CorrenteR),\n    CorrenteS: media(CorrenteS),\n    CorrenteT: media(CorrenteT),\n    ConsumoKW: media(ConsumoKW)\n};\n\n// Campos SÓ para debug/monitoramento\nmsg.CorrenteRcount = CorrenteR.length;\nmsg.CorrenteScount = CorrenteS.length;\nmsg.CorrenteTcount = CorrenteT.length;\nmsg.ConsumoKWcount = ConsumoKW.length;\n\nmsg.CorrenteRDesvio = desvioPadrao(CorrenteR);\nmsg.CorrenteSDesvio = desvioPadrao(CorrenteS);\nmsg.CorrenteTDesvio = desvioPadrao(CorrenteT);\nmsg.ConsumoKWDesvio = desvioPadrao(ConsumoKW);\n\n// Limpa arrays\nflow.set('CorrenteR', []);\nflow.set('CorrenteS', []);\nflow.set('CorrenteT', []);\nflow.set('ConsumoKW', []);\n\nmsg.operation = \"insertOne\";\nreturn msg;",
