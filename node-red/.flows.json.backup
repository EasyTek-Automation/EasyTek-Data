    {
        "id": "7ae705549b8fb70f",
        "type": "function",
        "z": "1b6420b8adb5a5b7",
        "name": "function 111",
        "func": "let Mist05_dadosOEE = flow.get('Mist05_dadosOEE') || [];\nlet Mist05_dadosDisp = flow.get('Mist05_dadosDisp') || [];\nlet Mist05_dadosDesemp = flow.get('Mist05_dadosDesemp') || [];\nlet Mist05_dadosQuali = flow.get('Mist05_dadosQuali') || [];\n\nfunction media(arr) {\n    if(arr.length === 0) return null;\n    return arr.reduce((a, b) => a + b, 0) / arr.length;\n}\n\nfunction desvioPadrao(arr) {\n    if (arr.length === 0) return null;\n    let m = media(arr);\n    let variancia = arr.reduce((acum, val) => acum + Math.pow(val - m, 2), 0) / arr.length;\n    return Math.sqrt(variancia);\n}\n\nlet agora = new Date();\n\nmsg.payload = {\n    DateTime: agora,\n    IDMaq: \"Decapado Mecânico\",\n    OEE: media(Mist05_dadosOEE),\n    Disp: media(Mist05_dadosDisp),\n    Desemp: media(Mist05_dadosDesemp),\n    Quali: media(Mist05_dadosQuali)\n};\n\n// Campos SÓ para debug/monitoramento\nmsg.OEEcount = Mist05_dadosOEE.length;\nmsg.Dispcount = Mist05_dadosDisp.length;\nmsg.Desempcount = Mist05_dadosDesemp.length;\nmsg.Qualicount = Mist05_dadosQuali.length;\n\nmsg.OEEDesvio = desvioPadrao(Mist05_dadosOEE);\nmsg.DispDesvio = desvioPadrao(Mist05_dadosDisp);\nmsg.DesempDesvio = desvioPadrao(Mist05_dadosDesemp);\nmsg.QualiDesvio = desvioPadrao(Mist05_dadosQuali);\n\n// Limpa arrays\nflow.set('Mist05_dadosOEE', []);\nflow.set('Mist05_dadosDisp', []);\nflow.set('Mist05_dadosDesemp', []);\nflow.set('Mist05_dadosQuali', []);\n\nmsg.operation = \"insertOne\";\nreturn msg;",
