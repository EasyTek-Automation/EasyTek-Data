    {
        "id": "024876d5f7a129b7",
        "type": "function",
        "z": "1b6420b8adb5a5b7",
        "name": "function 91",
        "func": "let Mist01_dadosOEE = flow.get('Mist01_dadosOEE') || [];\nlet Mist01_dadosDisp = flow.get('Mist01_dadosDisp') || [];\nlet Mist01_dadosDesemp = flow.get('Mist01_dadosDesemp') || [];\nlet Mist01_dadosQuali = flow.get('Mist01_dadosQuali') || [];\n\nfunction media(arr) {\n    if(arr.length === 0) return null;\n    return arr.reduce((a, b) => a + b, 0) / arr.length;\n}\n\nfunction desvioPadrao(arr) {\n    if (arr.length === 0) return null;\n    let m = media(arr);\n    let variancia = arr.reduce((acum, val) => acum + Math.pow(val - m, 2), 0) / arr.length;\n    return Math.sqrt(variancia);\n}\n\nlet agora = new Date();\n\nmsg.payload = {\n    DateTime: agora,\n    IDMaq: \"Decapado Mecânico\",\n    OEE: media(Mist01_dadosOEE),\n    Disp: media(Mist01_dadosDisp),\n    Desemp: media(Mist01_dadosDesemp),\n    Quali: media(Mist01_dadosQuali)\n};\n\n// Campos SÓ para debug/monitoramento\nmsg.OEEcount = Mist01_dadosOEE.length;\nmsg.Dispcount = Mist01_dadosDisp.length;\nmsg.Desempcount = Mist01_dadosDesemp.length;\nmsg.Qualicount = Mist01_dadosQuali.length;\n\nmsg.OEEDesvio = desvioPadrao(Mist01_dadosOEE);\nmsg.DispDesvio = desvioPadrao(Mist01_dadosDisp);\nmsg.DesempDesvio = desvioPadrao(Mist01_dadosDesemp);\nmsg.QualiDesvio = desvioPadrao(Mist01_dadosQuali);\n\n// Limpa arrays\nflow.set('Mist01_dadosOEE', []);\nflow.set('Mist01_dadosDisp', []);\nflow.set('Mist01_dadosDesemp', []);\nflow.set('Mist01_dadosQuali', []);\n\nmsg.operation = \"insertOne\";\nreturn msg;",
