        "type": "function",
        "z": "2b17cc635e977db5",
        "name": "function 85",
        "func": "// Guarda cada valor em um array separado no contexto de fluxo\nlet dadosQuali = flow.get('dadosQuali') || [];\ndadosQuali.push(msg.payload); // msg.payload aqui é só o valor do OEE\nflow.set('dadosQuali', dadosQuali);\nreturn null; // Não envia nada adiante por enquanto",
        "outputs": 0,
