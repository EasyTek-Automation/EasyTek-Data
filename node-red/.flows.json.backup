    {
        "id": "a3122fc599936faa",
        "type": "function",
        "z": "2b17cc635e977db5",
        "name": "function 127",
        "func": "// Lista de possíveis valores para o campo de status (string)\nconst statusPossiveis = [\"ATIVO\", \"INATIVO\", \"EM_MANUTENCAO\", \"FALHA\", \"OCIOSO\"];\n\n// --- Funções para gerar valores aleatórios ---\n\n// Gera um número inteiro aleatório entre um valor mínimo e máximo\nfunction getRandomInt(min, max) {\n    min = Math.ceil(min);\n    max = Math.floor(max);\n    return Math.floor(Math.random() * (max - min + 1)) + min;\n}\n\n// Gera um número de ponto flutuante (decimal) aleatório entre um mínimo e máximo\nfunction getRandomFloat(min, max) {\n    return Math.random() * (max - min) + min;\n}\n\n// --- Montagem do payload ---\n\n// O objeto msg.payload será o documento a ser inserido no MongoDB\nmsg.payload = {\n    // 1. Gera o timestamp. new Date() cria o objeto de data que o MongoDB entende.\n    \"timestamp\": new Date(),\n\n    // 2. Gera 5 valores numéricos aleatórios\n    \"leitura_sensor_1\": getRandomInt(0, 1000),\n    \"temperatura\": getRandomFloat(20.0, 95.5),\n    \"vibracao\": getRandomInt(10, 50),\n    \"pressao\": getRandomInt(1000, 9999),\n    \"consumo_energia\": getRandomFloat(50.0, 150.0),\n\n    // 3. Gera 1 valor string aleatório, escolhido da lista\n    \"status\": statusPossiveis[Math.floor(Math.random() * statusPossiveis.length)]\n};\n\n// Opcional: Se você estiver usando o nó do MongoDB, pode definir a operação.\n// Isso é útil se o mesmo nó de função for usado para diferentes operações.\n// msg.operation = \"insertOne\";\nmsg.operation = \"insertOne\";\n// Retorna a mensagem com o payload modificado para o próximo nó do fluxo.\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 1220,
        "wires": [
            [
                "07f9fcc6667e4f24"
            ]
        ]
