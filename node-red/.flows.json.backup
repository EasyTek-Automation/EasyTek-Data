    {
        "id": "6589d8372ef91d24",
        "type": "function",
        "z": "8e69476215f7ebaf",
        "g": "b836b91426a78051",
        "name": "function 1",
        "func": "// Verifica se msg.payload é um número e não é undefined ou null\nif (msg.payload !== undefined && msg.payload !== null) {\n    // Converte msg.payload para número e divide por 10000\n    msg.payload = Number(msg.payload) / 1000;\n    \n    // Obtém a parte decimal do número\n    msg.payload = msg.payload - Math.floor(msg.payload);\n    msg.payload = parseFloat(msg.payload.toFixed(4));\n\n} else {\n    // Emite um aviso se msg.payload for undefined ou null\n    node.warn(\"msg.payload is undefined or null\");\n}\n\n// Retorna a mensagem modificada\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 120,
        "wires": [
            [
                "ec02628adfedf811"
            ]
        ]
    },
    {
        "id": "b5a93c116c9a2c3a",
