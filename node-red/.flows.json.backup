        "func": "// Esta função será usada dentro de um nó de função no Node-RED\nif (typeof msg.payload === 'number' && msg.payload > 0) {\n    // Retorna a mensagem com apenas o topic e o payload\n    return { topic: msg.topic, payload: msg.payload };\n} else {\n    // Retorna null para interromper o fluxo se a condição não for atendida\n    return null;\n}\n",
