    {
        "id": "dc42dd6cd223179a",
        "type": "function",
        "z": "37e6316ce545a469",
        "name": "Split dos códigos",
        "func": "// Exemplo de código para o nó function\nlet valor = msg.payload; // Supondo que o valor DINT esteja em msg.payload\nlet tipoMaquina = Math.floor(valor / 1000000);\nlet qualMaquina = Math.floor((valor % 1000000) / 10000);\nlet categoriaFalha = Math.floor((valor % 10000) / 100);\nlet descricaoFalha = valor % 100;\n\nmsg.tipoMaquina = tipoMaquina;\nmsg.qualMaquina = qualMaquina;\nmsg.categoriaFalha = categoriaFalha;\nmsg.descricaoFalha = descricaoFalha;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 40,
        "wires": [
            [
                "65ad1687a4c0c15e"
            ]
        ]
    },
    {
        "id": "65ad1687a4c0c15e",
        "type": "file in",
        "z": "37e6316ce545a469",
        "name": "Local do Arquivo config",
        "filename": "/data/config.json",
        "filenameType": "str",
        "format": "utf8",
        "chunk": false,
        "sendError": false,
        "encoding": "none",
        "allProps": false,
        "x": 790,
        "y": 40,
        "wires": [
            [
                "dfe34cdc19e1ba6d"
            ]
        ]
    },
    {
        "id": "dfe34cdc19e1ba6d",
        "type": "function",
        "z": "37e6316ce545a469",
        "name": "Armazenando conteúdo",
        "func": "// Garante que está salvando como JSON de verdade\nlet config = {};\ntry {\n    config = JSON.parse(msg.payload);\n    global.set('config', config);\n    return msg;\n} catch (e) {\n    msg.payload = \"Erro ao carregar config.json: \" + e;\n    return msg;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1030,
        "y": 40,
        "wires": [
            [
                "2ad524e51892b71d"
            ]
        ]
    },
    {
        "id": "52ef63363b45f938",
        "type": "function",
        "z": "37e6316ce545a469",
        "name": "Carregando descrição de cada código",
        "func": "let config = global.get('config'); // Supondo que o arquivo JSON foi armazenado em um contexto global\n\nmsg.tipoMaquinaDesc = config.tipoMaquina[msg.tipoMaquina.toString().padStart(2, '0')];\nmsg.qualMaquinaDesc = config.qualMaquina[msg.qualMaquina.toString().padStart(2, '0')];\nmsg.categoriaFalhaDesc = config.categoriaFalha[msg.categoriaFalha.toString().padStart(2, '0')];\nmsg.descricaoFalhaDesc = config.descricaoFalha[msg.descricaoFalha.toString().padStart(2, '0')];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 100,
        "wires": [
            [
                "5d4a72c2423c8fc5"
            ]
        ]
    },
    {
        "id": "5d4a72c2423c8fc5",
        "type": "function",
        "z": "37e6316ce545a469",
        "name": "Gera String SQL",
        "func": "let moment = global.get('moment'); // Se quiser usar moment pra timezone, mas já vamos gerar o Date padrão\n\nlet tipoMaquinaDesc = msg.tipoMaquinaDesc;\nlet qualMaquinaDesc = msg.qualMaquinaDesc;\nlet categoriaFalhaDesc = msg.categoriaFalhaDesc;\nlet descricaoFalhaDesc = msg.descricaoFalhaDesc;\n\n// Verifica se alguma das variáveis é undefined\nif (\n    tipoMaquinaDesc === undefined ||\n    qualMaquinaDesc === undefined ||\n    categoriaFalhaDesc === undefined ||\n    descricaoFalhaDesc === undefined\n) {\n    msg.payload = \"Erro: Uma ou mais variáveis são undefined. Inserção no banco de dados cancelada.\";\n    return msg;\n}\n\n// Hora de São Paulo, sem milissegundos, no formato Date global (UTC)\nlet agora = new Date();\nagora.setMilliseconds(0); // Zera milissegundos (caso queira precisão só até os segundos)\n\n// Para ajustar para o fuso de São Paulo e exibir a ISO UTC correspondente:\nlet tz = moment().tz('America/Sao_Paulo');\n// Cria um objeto Date em UTC correspondente ao horário de São Paulo\nlet dateTimeSP = new Date(\n    Date.UTC(\n        tz.year(),\n        tz.month(),\n        tz.date(),\n        tz.hour(),\n        tz.minute(),\n        tz.second()\n    )\n);\n\n// Monta o objeto (como desejado para MongoDB ou JSON/API)\nmsg.payload = {\n    tipoMaquinaDesc: tipoMaquinaDesc,\n    qualMaquinaDesc: qualMaquinaDesc,\n    categoriaFalhaDesc: categoriaFalhaDesc,\n    descricaoFalhaDesc: descricaoFalhaDesc,\n    date_time: dateTimeSP // <-- este é um Date! MongoDB salva como ISODate, drivers/API serializam em ISO 8601.\n};\n\n// Opcional: marque a operação, se for para MongoDB no Node-RED\nmsg.operation = \"insertOne\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 100,
        "wires": [
            [
                "e2ec8ade754a23a4",
                "b8cab616118fb80e"
            ]
        ]
    },
