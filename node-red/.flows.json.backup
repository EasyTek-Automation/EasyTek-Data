    {
        "id": "aefaec5651f54cb3",
        "type": "inject",
        "z": "2b17cc635e977db5",
        "name": "Varredura 2min",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "120",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 120,
        "y": 1100,
        "wires": [
            [
                "35451cb15ad703f8"
            ]
        ]
    },
    {
        "id": "35451cb15ad703f8",
        "type": "function",
        "z": "2b17cc635e977db5",
        "name": "function 126",
        "func": "let TempR = flow.get('TempR') || [];\nlet TempS = flow.get('TempS') || [];\nlet TempT = flow.get('TempT') || [];\nlet TempKW = flow.get('TempKW') || [];\n\nfunction media(arr) {\n    if(arr.length === 0) return null;\n    return arr.reduce((a, b) => a + b, 0) / arr.length;\n}\n\nfunction desvioPadrao(arr) {\n    if (arr.length === 0) return null;\n    let m = media(arr);\n    let variancia = arr.reduce((acum, val) => acum + Math.pow(val - m, 2), 0) / arr.length;\n    return Math.sqrt(variancia);\n}\n\nlet agora = new Date();\n\nmsg.payload = {\n    DateTime: agora,\n    IDMaq: \"Decapado Mecânico\",\n    TempR: media(TempR),\n    TempS: media(TempS),\n    TempT: media(TempT),\n    TempKW: media(TempKW)\n};\n\n// Campos SÓ para debug/monitoramento\nmsg.TempRcount = TempR.length;\nmsg.TempScount = TempS.length;\nmsg.TempTcount = TempT.length;\nmsg.TempKWcount = TempKW.length;\n\nmsg.TempRDesvio = desvioPadrao(TempR);\nmsg.TempSDesvio = desvioPadrao(TempS);\nmsg.TempTDesvio = desvioPadrao(TempT);\nmsg.TempKWDesvio = desvioPadrao(TempKW);\n\n// Limpa arrays\nflow.set('TempR', []);\nflow.set('TempS', []);\nflow.set('TempT', []);\nflow.set('TempKW', []);\n\nmsg.operation = \"insertOne\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 1100,
        "wires": [
            [
                "9b82ab26df43f01c"
            ]
        ]
    },
