    {
        "id": "ecc4a97c448b261e",
        "type": "function",
        "z": "2d557e73cbc54abd",
        "g": "5b5ca10ce118bd5f",
        "name": "Gera String SQL",
        "func": "let moment = global.get('moment'); // Obtém o moment do contexto global\n\nlet tipoMaquinaDesc = msg.tipoMaquinaDesc;\nlet qualMaquinaDesc = msg.qualMaquinaDesc;\nlet categoriaFalhaDesc = msg.categoriaFalhaDesc;\nlet descricaoFalhaDesc = msg.descricaoFalhaDesc;\n\n// Verifica se alguma das variáveis é undefined\nif (tipoMaquinaDesc === undefined || qualMaquinaDesc === undefined || \n    categoriaFalhaDesc === undefined || descricaoFalhaDesc === undefined) {\n    // Opcional: Você pode configurar uma mensagem de erro no payload, se desejar informar o erro\n    msg.payload = \"Erro: Uma ou mais variáveis são undefined. Inserção no banco de dados cancelada.\";\n    return msg; // Retorna a mensagem sem executar a inserção no banco\n}\n\n// Ajusta o dateTime para o fuso horário de São Paulo, corrigindo a diferença de horas\nlet dateTime = moment().tz('America/Sao_Paulo').format('YYYY-MM-DD HH:mm:ss');\n\n// Criação da consulta SQL de inserção\nmsg.topic = `INSERT INTO tabela_falhas (tipoMaquinaDesc, qualMaquinaDesc, categoriaFalhaDesc, descricaoFalhaDesc, date_time) VALUES ('${tipoMaquinaDesc}', '${qualMaquinaDesc}', '${categoriaFalhaDesc}', '${descricaoFalhaDesc}', '${dateTime}')`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 830,
        "y": 100,
        "wires": [
            [
                "8de066c95acfe3a1"
            ]
        ]
    },
